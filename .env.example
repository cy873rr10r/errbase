# ── errbase + Cognee setup ─────────────────────────────────────────────────
# Pick ONE of the two backends below. Cloud is the simplest.

# ═══ OPTION A: Cognee Cloud  [SIMPLEST — recommended] ═══
# Get a key at https://platform.cognee.ai → just one line:
COGNEE_API_KEY="key here"
# (optional) COGNEE_API_URL="https://api.cognee.ai"

# ═══ OPTION B: Self-hosted (use your own Mistral key) ═══
# LLM_API_KEY="your_mistral_key_here"
# LLM_PROVIDER="mistral"
# LLM_MODEL="mistral/mistral-large-latest"
# EMBEDDING_PROVIDER="mistral"
# EMBEDDING_MODEL="mistral/mistral-embed"
# ENABLE_BACKEND_ACCESS_CONTROL="false"
# REQUIRE_AUTHENTICATION="false"

# ── Verify it's live ───────────────────────────────────────────────────────
#   errbase doctor      → runs a real remember→recall and reports status
#   errbase seed        → first real write to the Cognee graph (do before demo)
#
# With no key set, errbase runs on its local graph cache and still works.
#
# (optional) ERRBASE_COGNEE_FIRST="1"  → query Cognee before the local cache
